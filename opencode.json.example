{
  "$schema": "https://opencode.ai/config.json",
  "model": "mlx/mlx-community/Qwen3.5-9B-OptiQ-4bit",
  "default_agent": "build",
  "provider": {
    "mlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "not-needed",
        "timeout": 600000
      },
      "models": {
        "mlx-community/Qwen3.5-9B-OptiQ-4bit": {
          "name": "Qwen3.5 9B OptiQ 4-bit MLX (default)",
          "tool_call": true,
          "context_length": 32768,
          "max_tokens": 8192
        }
      }
    }
  },
  "mcp": {
    "foundry": {
      "type": "remote",
      "enabled": false,
      "url": "FOUNDRY_MCP_URL",
      "headers": {
        "Authorization": "Bearer {env:FOUNDRY_MCP_TOKEN}",
        "Accept": "application/json, text/event-stream"
      }
    },
    "github": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "context7": {
      "type": "remote",
      "enabled": false,
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "sentry": {
      "type": "remote",
      "enabled": false,
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {}
    }
  },
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "task": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "tool": {
      "edit": "ask"
    },
    "edit": "ask",
    "write": "ask",
    "apply_patch": "ask",
    "bash": {
      "*": "ask",
      "which *": "allow",
      "opencode *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "cd *": "allow",
      "find *": "allow",
      "tree *": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "pytest *": "allow",
      "python3 *": "ask",
      "node *": "ask",
      "nvm install *": "ask",
      "npm run test *": "allow",
      "make test *": "allow",
      "git push*": "ask",
      "git commit*": "ask",
      "npm publish*": "deny",
      "docker push*": "deny",
      "rm *": "deny",
      "sudo *": "deny"
    }
  },
  "agent": {
    "build": {
      "permission": {
        "task": "allow"
      }
    }
  }
}

# Active local model pins — native MLX (Apple mlx-lm server)

PRIMARY_MODEL=mlx-community/Qwen3.5-9B-OptiQ-4bit
OPENCODE_MODEL_ID=mlx-community/Qwen3.5-9B-OptiQ-4bit
PRIMARY_QUANT=4bit
PRIMARY_RAM_GB=9
PRIMARY_DISK_GB=8

MLX_HOST=127.0.0.1
MLX_PORT=8080
MLX_API_BASE=http://127.0.0.1:8080
MLX_MAX_TOKENS=8192
MLX_CHAT_TEMPLATE_ARGS='{"enable_thinking":false}'

AGENT=opencode
AGENT_CONFIG=~/.config/opencode/opencode.json
LONG_TASK_COMMAND=./scripts/loop.sh

AGENT_CONTEXT_LENGTH=32768
AGENT_MAX_TOKENS=8192

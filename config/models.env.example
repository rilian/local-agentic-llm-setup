# Active local model pins — copy to models.env and edit

PRIMARY_MODEL=qwen3-coder:30b
PRIMARY_QUANT=Q4_K_M
PRIMARY_RAM_GB=17
PRIMARY_DISK_GB=18

FAST_MODEL=qwen3-coder:14b
FAST_QUANT=Q4_K_M
FAST_RAM_GB=8
FAST_DISK_GB=9

OLLAMA_API_BASE=http://127.0.0.1:11434

# Terminal agent
AGENT=opencode
AGENT_CONFIG=~/.config/opencode/opencode.json
LONG_TASK_COMMAND=./scripts/loop.sh

AGENT_CONTEXT_LENGTH=65536
AGENT_MAX_TOKENS=8192

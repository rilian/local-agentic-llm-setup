{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "foundry": {
      "type": "remote",
      "url": "https://proxet.palantirfoundry.com/mcp/third-party-application/ri.third-party-applications.main.application.ID_OF_MCP",
      "headers": {
        "Authorization": "Bearer LONG_LIVING_TOKEN_WITH_PROPER_SCOPE",
        "Accept": "application/json, text/event-stream"
      }
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/path/to/allowed/dir"],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "enabled": true,
      "oauth": {}
    }
  },
  "tools": {
    "filesystem_*": false
  }
}
